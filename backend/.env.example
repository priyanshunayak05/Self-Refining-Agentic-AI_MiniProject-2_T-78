# ─── Required ─────────────────────────────────────────────────────────────────
# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# Get your free Groq API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret — change this to a long random string in production!
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# ─── Optional ─────────────────────────────────────────────────────────────────
# Override default Groq model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Port to run the server on (default: 5000)
PORT=5000

# Set to 'production' in Render environment
NODE_ENV=development

# Optional: restrict CORS to a specific custom frontend domain
FRONTEND_URL=
