# ─── Required ─────────────────────────────────────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Override default Groq model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Port to run the server on (default: 5000)
PORT=5000

# Set to 'production' in Render environment
NODE_ENV=development

# Optional: restrict CORS to a specific custom frontend domain
# *.vercel.app and localhost are always allowed — only set this for a custom domain
FRONTEND_URL=
